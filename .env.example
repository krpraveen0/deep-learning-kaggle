# Copy this file to .env for local use only.
# Never commit real credentials.

# Kaggle API credentials
# New API Token (Recommended, kaggle CLI >= 1.8.0): set only KAGGLE_KEY.
# Legacy credentials: set both KAGGLE_USERNAME and KAGGLE_KEY.
KAGGLE_USERNAME=your_kaggle_username   # omit or leave blank when using a new API token
KAGGLE_KEY=your_kaggle_api_key_or_new_token

# Optional: canonical kernel owner used in scripts/docs
KAGGLE_OWNER=krpraveen0
