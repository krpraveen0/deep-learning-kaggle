# Copy this file to .env for local use only.
# Never commit real credentials.

# Kaggle API credentials — choose ONE of the two approaches below:

# ── Recommended: new API token (kaggle CLI >= 1.8.0) ──────────────────────────
# Create a token at: kaggle.com → Settings → API → API Tokens → Create New Token
# Kaggle downloads a kaggle.json file; paste its entire contents here.
# KAGGLE_TOKEN={"key":"<paste-token-here>"}

# ── Legacy fallback: username + API key ───────────────────────────────────────
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Optional: canonical kernel owner used in scripts/docs
KAGGLE_OWNER=krpraveen0
