# Copy this file to .env for local use only.
# Never commit real credentials.

# Kaggle API token (Kaggle → Settings → API → API Tokens → Create New Token)
KAGGLE_KEY=your_kaggle_api_token

# Optional: canonical kernel owner used in scripts/docs
KAGGLE_OWNER=krpraveen0

# ── Notebook runtime configuration ───────────────────────────────────────────
# These environment variables are read by the config cell at the top of each
# notebook. Set them here (or export them in your shell) to override the
# built-in defaults without editing notebook source.

# GPU usage: set to "false" to force CPU-only execution (modules 04–06, 08).
# Must be set before TensorFlow is imported (i.e., before the training cell).
USE_GPU=true

# Training hyperparameters shared across modules (each module has its own default).
EPOCHS=2
BATCH_SIZE=128

# Sample counts for CNN modules (04 and 08).
TRAIN_SAMPLES=6000
TEST_SAMPLES=1000

# RNN window size (module 05).
WINDOW=4

# EarlyStopping patience (module 07).
PATIENCE=8

# Backprop learning rate (module 03).
LEARNING_RATE=0.001

# ── Kaggle metadata overrides (used by scripts/normalize_metadata.py) ────────
# These can also be passed as CLI flags (--enable-gpu, --enable-internet,
# --is-private) or as workflow_dispatch inputs in GitHub Actions.
# Leave commented out to use the per-module defaults in kernel-metadata.json.
# ENABLE_GPU=true
# ENABLE_INTERNET=false
# IS_PRIVATE=false
